@page "/monthly"
@inject RecurrenceService Svc

<PageTitle>Monthly — DateRecurrenceR Demo</PageTitle>

<PageLayout Title="monthly" Description="by day of month or day_of_week + week_number" Result="@_result">

        <div class="config-form">
            <div class="panel-title">// pattern configuration</div>

            <div class="mode-tabs mb-3">
                <button class="mode-tab @(_subMode == 0 ? "active" : "")" @onclick="@(() => _subMode = 0)">by_day_of_month</button>
                <button class="mode-tab @(_subMode == 1 ? "active" : "")" @onclick="@(() => _subMode = 1)">by_day_of_week</button>
            </div>

            <div class="form-row">
                <MudDatePicker Label="Begin Date"
                               Date="@_beginDateDt"
                               DateChanged="@(d => _beginDate = d.HasValue ? DateOnly.FromDateTime(d.Value) : _beginDate)"
                               DateFormat="yyyy-MM-dd" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />

                @if (_subrangeMode != SubrangeMode.ByCount)
                {
                    <MudDatePicker Label="End Date"
                                   Date="@_endDateDt"
                                   DateChanged="@(d => _endDate = d.HasValue ? DateOnly.FromDateTime(d.Value) : _endDate)"
                                   DateFormat="yyyy-MM-dd" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3" />
                }
            </div>

            <MudNumericField T="int" Label="Interval (months)" @bind-Value="_interval"
                             Min="1" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3"
                             Style="max-width:160px;" />

            @if (_subMode == 0)
            {
                <MudNumericField T="int" Label="Day of Month (1–31)" @bind-Value="_dayOfMonth"
                                 Min="1" Max="31" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3"
                                 Style="max-width:160px;" />
            }
            else
            {
                <MudSelect T="DayOfWeek" Label="Day of Week" @bind-Value="_dayOfWeek"
                           Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                    @foreach (DayOfWeek d in Enum.GetValues<DayOfWeek>())
                    {
                        <MudSelectItem Value="d">@d</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="IndexOfDay" Label="Week in Month" @bind-Value="_indexOfDay"
                           Margin="Margin.Dense" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="IndexOfDay.First">First</MudSelectItem>
                    <MudSelectItem Value="IndexOfDay.Second">Second</MudSelectItem>
                    <MudSelectItem Value="IndexOfDay.Third">Third</MudSelectItem>
                    <MudSelectItem Value="IndexOfDay.Fourth">Fourth</MudSelectItem>
                    <MudSelectItem Value="IndexOfDay.Last">Last</MudSelectItem>
                </MudSelect>
            }

            <SubrangeSelector Mode="@_subrangeMode" ModeChanged="@(m => _subrangeMode = m)"
                              FromDate="@_fromDate" FromDateChanged="@(d => _fromDate = d)"
                              ToDate="@_toDate" ToDateChanged="@(d => _toDate = d)"
                              Count="@_count" CountChanged="@(c => _count = c)" />

            @if (_error != null)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
            }

            <button class="btn-generate" @onclick="Generate">generate</button>
        </div>

</PageLayout>

@code {
    private DateOnly _beginDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _endDate = DateOnly.FromDateTime(DateTime.Today.AddYears(2));
    private int _interval = 1;
    private int _subMode = 0; // 0 = ByDayOfMonth, 1 = ByDayOfWeek
    private int _dayOfMonth = 1;
    private DayOfWeek _dayOfWeek = DayOfWeek.Monday;
    private IndexOfDay _indexOfDay = IndexOfDay.First;
    private SubrangeMode _subrangeMode = SubrangeMode.None;
    private DateOnly? _fromDate;
    private DateOnly? _toDate;
    private int _count = 10;
    private string? _error;
    private RecurrenceResult? _result;

    private DateTime? _beginDateDt => _beginDate.ToDateTime(TimeOnly.MinValue);
    private DateTime? _endDateDt => _endDate.ToDateTime(TimeOnly.MinValue);

    private void Generate()
    {
        _error = null;
        if (!Validate()) return;

        try
        {
            int? countArg = _subrangeMode == SubrangeMode.ByCount ? _count : null;

            _result = _subMode == 0
                ? Svc.GetMonthlyByDayOfMonth(_beginDate, _endDate, _interval, _dayOfMonth, _subrangeMode, _fromDate, _toDate, countArg)
                : Svc.GetMonthlyByDayOfWeek(_beginDate, _endDate, _interval, _dayOfWeek, _indexOfDay, _subrangeMode, _fromDate, _toDate, countArg);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private bool Validate()
    {
        if (_subrangeMode != SubrangeMode.ByCount && _beginDate > _endDate) { _error = "Begin date must be ≤ end date."; return false; }
        if (_interval < 1) { _error = "Interval must be ≥ 1."; return false; }
        if (_subMode == 0 && (_dayOfMonth < 1 || _dayOfMonth > 31)) { _error = "Day of month must be between 1 and 31."; return false; }
        if (_subrangeMode == SubrangeMode.ByDates && _fromDate.HasValue && _toDate.HasValue && _fromDate > _toDate) { _error = "From date must be ≤ to date."; return false; }
        if (_subrangeMode == SubrangeMode.ByCount && _count < 1) { _error = "Count must be ≥ 1."; return false; }
        return true;
    }
}
