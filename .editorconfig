[*.{csproj,vbproj,vcxproj,vcxproj.filters,proj,projitems,shproj}]
indent_size = 4

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[test/**/*.cs]
# Test methods conventionally use underscores in names
dotnet_diagnostic.CA1707.severity = none

[*.md]
trim_trailing_whitespace = false
